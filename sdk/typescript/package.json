{
  "name": "@memos/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Distributed MemOS - Adaptive memory infrastructure for autonomous AI agents",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "require": "./dist/adapters/index.js",
      "default": "./dist/adapters/index.js"
    },
    "./adapters/*": {
      "types": "./dist/adapters/*.d.ts",
      "require": "./dist/adapters/*.js",
      "default": "./dist/adapters/*.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mohi1038/distributed-memOS.git"
  },
  "keywords": [
    "memory",
    "ai",
    "vector-db",
    "adaptive-retrieval",
    "semantic-search",
    "agents",
    "reinforcement"
  ],
  "author": "MemOS Team",
  "license": "Apache-2.0",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.json",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run prepack"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.11.0",
    "@grpc/proto-loader": "^0.7.13",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "proto",
    "README.md",
    "LICENSE"
  ]
}
